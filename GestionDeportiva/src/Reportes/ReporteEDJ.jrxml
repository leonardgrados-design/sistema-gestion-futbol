	<queryString language="SQL">
		<![CDATA[SELECT
     estadisticas_deportivas.`id_deportivo` AS estadisticas_deportivas_id_deportivo,
     estadisticas_deportivas.`id_jugador` AS estadisticas_deportivas_id_jugador,
     estadisticas_deportivas.`fecha_registro` AS estadisticas_deportivas_fecha_registro,
     estadisticas_deportivas.`goles` AS estadisticas_deportivas_goles,
     estadisticas_deportivas.`asistencias` AS estadisticas_deportivas_asistencias,
     estadisticas_deportivas.`faltas` AS estadisticas_deportivas_faltas,
     estadisticas_deportivas.`minutos_entrenados` AS estadisticas_deportivas_minutos_entrenados,
     estadisticas_deportivas.`velocidad_max` AS estadisticas_deportivas_velocidad_max,
     estadisticas_deportivas.`resistencia` AS estadisticas_deportivas_resistencia,
     jugadores.`id_jugador` AS jugadores_id_jugador,
     jugadores.`nombre` AS jugadores_nombre,
     jugadores.`apellido` AS jugadores_apellido,
     jugadores.`fecha_nacimiento` AS jugadores_fecha_nacimiento,
     jugadores.`telefono` AS jugadores_telefono,
     jugadores.`correo` AS jugadores_correo,
     jugadores.`posicion` AS jugadores_posicion,
     jugadores.`fecha_registro` AS jugadores_fecha_registro
FROM
     `jugadores` jugadores INNER JOIN `estadisticas_deportivas` estadisticas_deportivas ON jugadores.`id_jugador` = estadisticas_deportivas.`id_jugador`]]>
	</queryString>
