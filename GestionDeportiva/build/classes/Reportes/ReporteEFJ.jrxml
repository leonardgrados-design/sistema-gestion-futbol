	<queryString language="SQL">
		<![CDATA[SELECT
     estadisticas_fisicas.`id_fisico` AS estadisticas_fisicas_id_fisico,
     estadisticas_fisicas.`id_jugador` AS estadisticas_fisicas_id_jugador,
     estadisticas_fisicas.`fecha_registro` AS estadisticas_fisicas_fecha_registro,
     estadisticas_fisicas.`peso` AS estadisticas_fisicas_peso,
     estadisticas_fisicas.`altura` AS estadisticas_fisicas_altura,
     estadisticas_fisicas.`porcentaje_grasa` AS estadisticas_fisicas_porcentaje_grasa,
     estadisticas_fisicas.`masa_muscular` AS estadisticas_fisicas_masa_muscular,
     estadisticas_fisicas.`imc` AS estadisticas_fisicas_imc,
     jugadores.`id_jugador` AS jugadores_id_jugador,
     jugadores.`nombre` AS jugadores_nombre,
     jugadores.`apellido` AS jugadores_apellido,
     jugadores.`fecha_nacimiento` AS jugadores_fecha_nacimiento,
     jugadores.`telefono` AS jugadores_telefono,
     jugadores.`correo` AS jugadores_correo,
     jugadores.`posicion` AS jugadores_posicion,
     jugadores.`fecha_registro` AS jugadores_fecha_registro
FROM
     `jugadores` jugadores INNER JOIN `estadisticas_fisicas` estadisticas_fisicas ON jugadores.`id_jugador` = estadisticas_fisicas.`id_jugador`]]>
	</queryString>
